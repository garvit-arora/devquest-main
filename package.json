{
  "name": "devquest-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "description": "DevQuest AI monorepo for quests, credits, and OpenAI-compatible model access.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "dev:api": "python -m uvicorn apps.api.devquest_api.main:app --reload --port 8000",
    "test:api": "python -m pytest apps/api/tests"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0",
    "python": ">=3.11"
  }
}
