# DevQuest AI root environment.
# Copy to `.env` for Docker/API local development. Never commit real secrets.

# Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEVQUEST_GATEWAY_URL=http://localhost:8000/v1
DEVQUEST_BACKEND_ORIGIN=http://localhost:8000
# Production example:
# NEXT_PUBLIC_APP_URL=https://devquest.garvitarora.xyz
# NEXT_PUBLIC_API_URL=https://devquest.garvitarora.xyz
# NEXT_PUBLIC_DEVQUEST_GATEWAY_URL=https://devquest.garvitarora.xyz/v1
# DEVQUEST_BACKEND_ORIGIN=https://devquest-bdayfba2arh9h6ch.canadacentral-01.azurewebsites.net

# Application secrets
SESSION_SECRET=replace-with-32-random-bytes
DEVQUEST_API_KEY_PEPPER=replace-with-api-key-pepper
DEVQUEST_REFERRAL_REWARD_CREDITS=100

# Admin dashboard credentials. Store only hashes.
# Generate a hash with:
# python -c "import hashlib; print(hashlib.sha256(b'YOUR_ADMIN_PEPPER:YOUR_PASSWORD').hexdigest())"
DEVQUEST_ADMIN_PASSWORD_PEPPER=replace-with-admin-password-pepper
DEVQUEST_ADMIN_USERNAME=
DEVQUEST_ADMIN_PASSWORD_HASH=
DEVQUEST_ADMIN_ROLE=admin
# Or seed multiple admins:
# DEVQUEST_ADMIN_USERS=[{"username":"owner","password_hash":"sha256_hash_here","role":"owner","display_name":"Owner"}]

# GitHub OAuth and webhooks
# GitHub OAuth App homepage URL: http://localhost:3000
# GitHub OAuth App callback URL: http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret

# MongoDB persistence. Put your full MongoDB Atlas/local URI here.
# Atlas example:
# MONGODB_URI=mongodb+srv://garvit:<db_password>@learning.3u2np.mongodb.net/devquest?retryWrites=true&w=majority&appName=Learning
# Local Docker example:
# MONGODB_URI=mongodb://devquest:devquest@localhost:27017/devquest?authSource=admin
MONGODB_URI=
MONGODB_DATABASE=devquest

# API key storage
# Raw API keys are shown once and are never persisted. Database records store only prefix + key_hash + metadata.

# Approved repository campaigns are stored in MongoDB `repository_campaigns`.
# Seed/update one with:
# python -m apps.api.devquest_api.seed_repository_campaign --owner your-org --name your-repo --url https://github.com/your-org/your-repo --description "Campaign" --reward-credits 200 --status active --sponsor-name "Your Company"
DEVQUEST_APPROVED_REPOS=

# Pull request reward campaigns. A user's merged PR in one of these repos awards 150 credits once.
# DEVQUEST_PR_REPOS=[{"owner":"your-org","name":"your-repo","description":"Meaningful PRs only","reward_credits":150,"status":"active","sponsor_name":"Your Company"}]
DEVQUEST_PR_REPOS=

# Issue bounty campaigns. A user's merged PR must close the configured issue before credits are awarded.
# DEVQUEST_ISSUE_BOUNTIES=[{"owner":"your-org","name":"your-repo","issue_number":12,"title":"Fix bug","description":"Close issue #12 with a merged PR.","kind":"fix_issue","reward_credits":500,"status":"active","sponsor_name":"Your Company"}]
DEVQUEST_ISSUE_BOUNTIES=

# Optional bounty board tasks beyond star and PR campaigns.
# DEVQUEST_BOUNTY_TASKS=[{"id":"fix-issue-1","type":"fix_issue","title":"Fix issue","repository":"your-org/your-repo","description":"Fix an approved issue and submit the merged PR.","reward_credits":500,"status":"available","external_url":"https://github.com/your-org/your-repo/issues"}]
DEVQUEST_BOUNTY_TASKS=

# Limited-time credit boosts. Only configured active events affect payouts.
# DEVQUEST_CREDIT_BOOST_EVENTS=[{"id":"weekend-pr-rush","title":"Weekend PR Rush","kind":"pull_request","multiplier":2,"starts_at":"2026-07-17T00:00:00Z","ends_at":"2026-07-20T00:00:00Z"},{"id":"docs-week","title":"Docs Week","kind":"write_docs","bonus_credits":100,"starts_at":"2026-07-20T00:00:00Z","ends_at":"2026-07-27T00:00:00Z"},{"id":"first-50-merged-prs","title":"First 50 merged PRs","kind":"pull_request","bonus_credits":100,"first_n":50}]
DEVQUEST_CREDIT_BOOST_EVENTS=

# Azure-hosted OpenAI-compatible provider. Keep deployment names private.
DEVQUEST_PROVIDER_BASE_URL=https://your-resource.openai.azure.com/openai/v1
DEVQUEST_PROVIDER_API_KEY=
DEVQUEST_PROVIDER_API_VERSION=
DEVQUEST_PUBLIC_MODELS=DeepSeek-V4-Pro,gpt-5.5,gpt-5.6-luna,gpt-5.6-sol
DEVQUEST_DEEPSEEK_V4_PRO_MODEL=DeepSeek-V4-Pro
DEVQUEST_AZURE_GPT_55_MODEL=gpt-5.5
DEVQUEST_AZURE_GPT_56_LUNA_MODEL=gpt-5.6-luna
DEVQUEST_AZURE_GPT_56_SOL_MODEL=gpt-5.6-sol
DEVQUEST_GPT_56_SOL_MODEL=gpt-5.6-sol
DEVQUEST_GPT_55_MODEL=gpt-5.5
DEVQUEST_LUNA_MODEL=luna
DEVQUEST_DEEPSEEK_55_MODEL=deepseek-5.5
DEVQUEST_DEEPSEEK_RESEARCH_MODEL=deepseek-research
DEVQUEST_FAST_MODEL=
DEVQUEST_REASON_MODEL=
DEVQUEST_CODE_MODEL=
DEVQUEST_DEEPSEEK_MODEL=
DEVQUEST_EMBED_MODEL=
DEVQUEST_RESEARCH_MODEL=
DEVQUEST_MINI_MODEL=

# Gateway limits
DEVQUEST_MAX_REQUESTS_PER_MINUTE=5
DEVQUEST_MAX_REQUESTS_PER_DAY=100
DEVQUEST_MAX_CONCURRENT_REQUESTS=1
DEVQUEST_MAX_INPUT_CHARS=24000
DEVQUEST_MAX_OUTPUT_TOKENS=2048
DEVQUEST_MAX_MODELS_PER_KEY=1
DEVQUEST_MAX_CREDITS_PER_REQUEST=2

# Redis cache / rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Azure services
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_STAR_QUEUE=github-star-verification
AZURE_SERVICE_BUS_NOTIFICATION_QUEUE=devquest-user-notifications
AZURE_KEY_VAULT_URL=
AZURE_COMMUNICATION_EMAIL_CONNECTION_STRING=
AZURE_COMMUNICATION_EMAIL_SENDER=
DEVQUEST_OWNER_EMAIL=

# Sponsor review fee shown before sponsor campaign submission.
# Set either a hosted QR image URL or a UPI ID. If only UPI ID is set, the app generates a QR image URL for display.
DEVQUEST_SPONSOR_REVIEW_FEE_INR=100
# Leave empty to use the bundled frontend image at apps/web/public/qr.png.
DEVQUEST_SPONSOR_PAYMENT_QR_URL=
DEVQUEST_SPONSOR_PAYMENT_UPI_ID=
DEVQUEST_SPONSOR_PAYMENT_RECIPIENT=DevQuest AI
