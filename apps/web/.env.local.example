# Next.js public runtime config.
# Copy to `apps/web/.env.local` when running the web app outside Docker.
# Do not put GitHub client secrets in this file. Those belong in the root `.env`.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEVQUEST_GATEWAY_URL=http://localhost:8000/v1

# Production on Vercel can avoid third-party cookie blocking by using the
# frontend origin for public API calls and proxying to Azure server-side.
# NEXT_PUBLIC_API_URL=https://devquest.garvitarora.xyz
# NEXT_PUBLIC_DEVQUEST_GATEWAY_URL=https://devquest.garvitarora.xyz/v1
# DEVQUEST_BACKEND_ORIGIN=https://devquest-bdayfba2arh9h6ch.canadacentral-01.azurewebsites.net
